# EvidenceCompare AI — environment for docker compose.
# Copy to `.env` and fill in secrets. Do NOT commit `.env`.

# --- Postgres (the db service) ---
POSTGRES_USER=evidence
POSTGRES_PASSWORD=evidence
POSTGRES_DB=evidencecompare

# --- API ---
# Generate a strong value, e.g. `openssl rand -hex 32`.
JWT_SECRET=change-me-in-production
CORS_ORIGINS=http://localhost:3000

# Pipeline dispatch: celery (uses the worker) | background (in-process) | eager
PIPELINE_MODE=celery

# Evidence + LLM modes: auto | live | offline.
# `auto`/`live` need the API keys below; with no keys the engine falls back to
# offline fixtures + extractive synthesis (fully functional, no external calls).
EVIDENCE_MODE=auto
LLM_MODE=auto
ANTHROPIC_API_KEY=
VOYAGE_API_KEY=
NCBI_EMAIL=you@example.com
NCBI_API_KEY=

# --- Web ---
# Baked into the browser bundle at build time — must be reachable from the user's
# browser (the host), not the internal compose network name.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
