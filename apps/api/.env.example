# --- App ---
APP_NAME=EvidenceCompare AI
ENV=dev                          # dev | prod | test
LOG_LEVEL=INFO

# --- Database ---
# Dev default is SQLite; prod uses Postgres + pgvector (Phase 3).
DATABASE_URL=sqlite+aiosqlite:///./evidencecompare.db
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/evidencecompare

# --- Auth ---
JWT_SECRET=change-me-in-production
JWT_ALG=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14

# --- Redis / Celery (Phase 2 wiring; optional in dev) ---
REDIS_URL=redis://localhost:6379/0

# --- CORS ---
CORS_ORIGINS=http://localhost:3000

# --- Pipeline ---
PIPELINE_MODE=background         # background | eager | celery
PIPELINE_STEP_DELAY=0.5          # seconds per simulated agent step

# --- Evidence + LLM modes ---
# auto  = try live (needs keys below); fall back to offline if unavailable
# live  = force live (fails loudly without keys/network)
# offline = deterministic fixtures + extractive synthesis (no external calls)
# Leaving the keys blank ⇒ the app runs fully in offline mode. Set ANTHROPIC_API_KEY
# (and ideally NCBI + Voyage) and use auto/live to get genuinely dynamic, LLM-written
# reports from current literature.
EVIDENCE_MODE=auto
LLM_MODE=auto

# --- AI providers ---
ANTHROPIC_API_KEY=               # required for live LLM synthesis + agents
VOYAGE_API_KEY=                  # embeddings; blank ⇒ offline hashed-BoW fallback
NCBI_EMAIL=you@example.com       # polite PubMed identification
NCBI_API_KEY=                    # higher PubMed rate limits (optional)
MODEL_SYNTHESIS=claude-opus-4-8
MODEL_AGENT=claude-sonnet-5
MODEL_EXTRACT=claude-haiku-4-5
EMBEDDING_MODEL=voyage-3.5

# --- Report caching + living evidence ---
REPORT_CACHE_TTL_HOURS=168       # reuse a completed report for the same query within this window
FRESHNESS_STALE_HOURS=168        # periodic living-evidence sweep re-checks reports older than this
